---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import { packages } from "../config/packages";
import { serviceById } from "../config/services";

const packageData = packages.map((item) => ({
  ...item,
  services: item.availableServiceIds.map((id) => serviceById[id]),
}));
---

<BaseLayout
  title="GHALY GENTS SALON | صالون غالي للرجال"
  description="الفخامة تبدأ من العناية بنفسك. خدمة احترافية، نتائج مضمونة، رضاكم هو هدفنا."
>
  <main>
    <section class="brand-intro">
      <div class="site-container brand-intro-inner">
        <button class="language-switch" id="language-switch" type="button">English</button>
        <img
          src="/brand/ghaly-lion-logo.png"
          alt="GHALY GENTS SALON"
          width="300"
          height="350"
          fetchpriority="high"
        />
        <p data-i18n="heroEyebrow">LUXURY STARTS WITH SELF CARE</p>
        <h1 data-i18n="heroTitle">الفخامة تبدأ من العناية بنفسك</h1>
        <div class="hero-badges">
          <span data-i18n="professionalService">خدمة احترافية</span>
          <span data-i18n="guaranteedResults">نتائج مضمونة</span>
          <span data-i18n="satisfactionGoal">رضاكم هو هدفنا</span>
        </div>
      </div>
    </section>

    <section class="offers-section">
      <div class="site-container offers-stack">
        {packages.map((item) => (
          <article class:list={["offer-card", item.code === "royal_vip_300" && "offer-card-royal"]}>
            <button
              class="offer-card-trigger"
              type="button"
              data-package-code={item.code}
              aria-label={`اختيار ${item.ar}`}
            ></button>
            <header class="offer-card-header">
              <div>
                <p>{item.en}</p>
                <h2 data-package-ar={item.ar} data-package-en={item.en}>{item.ar}</h2>
              </div>
              <div class="offer-price">
                <strong>{item.price}</strong>
                <span>درهم · AED</span>
              </div>
            </header>

            <div class="offer-rule">
              <Icon name={item.code === "royal_vip_300" ? "solar:crown-star-bold" : "solar:scissors-square-bold"} />
              <strong>{item.fixedServiceIds ? "5 SERVICES INCLUDED" : `CHOOSE ANY ${item.limit} SERVICES`}</strong>
              <span
                data-package-rule
                data-fixed={String(Boolean(item.fixedServiceIds))}
                data-limit={item.limit}
              >{item.fixedServiceIds ? "الخدمات المشمولة" : `اختر ${item.limit} خدمات بمزاجك`}</span>
            </div>

            <ul class="offer-services">
              {item.exampleServiceIds.map((id) => serviceById[id]).map((service) => (
                <li>
                  <span class="offer-service-icon">
                    <Icon name={service.icon} />
                    {service.modifierIcon && <Icon class="offer-service-modifier" name={service.modifierIcon} />}
                  </span>
                  <span>
                  <strong data-service-ar={service.ar} data-service-en={service.en}>{service.ar}</strong>
                  <small data-service-secondary data-service-ar={service.ar} data-service-en={service.en}>{service.en}</small>
                  </span>
                </li>
              ))}
            </ul>

            <footer class="offer-card-footer">
              {item.fixedServiceIds ? (
                <>
                  <strong data-i18n="fiveIncluded">5 خدمات مشمولة</strong>
                  <span>5 SERVICES INCLUDED</span>
                </>
              ) : (
                <>
                <strong
                  data-available-rule
                  data-limit={item.limit}
                  data-available={item.availableServiceIds.length}
                >اختر {item.limit} خدمات من بين {item.availableServiceIds.length} خدمة متاحة</strong>
                <span>PLEASE CHOOSE ANY {item.limit} SERVICES</span>
                </>
              )}
            </footer>
          </article>
        ))}
      </div>
    </section>

    <dialog class="order-modal" id="order-modal" aria-labelledby="modal-title">
      <div class="modal-frame">
        <header class="modal-header">
          <div>
            <p id="modal-package-name">GHALY GENTS SALON</p>
            <h2 id="modal-title" data-i18n="formTitle">استمارة اختيار الخدمات</h2>
          </div>
          <button class="modal-close" type="button" data-close-modal aria-label="إغلاق">
            <Icon name="solar:close-circle-linear" />
          </button>
        </header>

        <div class="modal-progress" aria-label="مراحل استمارة اختيار الخدمات">
          <span class="is-active" data-progress="services" data-i18n="services">الخدمات</span>
          <span data-progress="details" data-i18n="details">البيانات</span>
          <span data-progress="confirm" data-i18n="confirm">التأكيد</span>
        </div>

        <section class="modal-step is-active" data-step="services">
          <div class="selection-heading">
            <div>
              <h3 id="selection-title">يرجى الاختيار</h3>
              <p id="selection-description"></p>
            </div>
            <div class="selection-counter">
              <strong id="selection-count">0</strong>
              <span id="selection-limit">/ 0</span>
            </div>
          </div>
          <div class="selection-grid" id="selection-grid"></div>
          <p class="auto-continue" id="auto-continue" hidden>
            <span data-i18n="autoContinue">الانتقال إلى البيانات خلال</span> <strong id="auto-seconds">30</strong> <span data-i18n="seconds">ثانية</span>
          </p>
          <div class="modal-actions">
            <button class="modal-button modal-button-muted" type="button" data-close-modal data-i18n="back">تراجع</button>
            <button class="modal-button modal-button-gold" id="continue-details" type="button" disabled data-i18n="continue">استمرار</button>
          </div>
        </section>

        <section class="modal-step" data-step="details">
          <h3 data-i18n="details">البيانات</h3>
          <form class="customer-form" id="customer-form">
            <label>
              <span data-i18n="nameLabel">الاسم / Name</span>
              <input name="customerName" autocomplete="name" required />
            </label>
            <label>
              <span data-i18n="phoneLabel">رقم الهاتف / Phone</span>
              <input name="phone" dir="ltr" inputmode="tel" autocomplete="tel" required />
            </label>
            <label>
              <span data-i18n="arrivalDate">تاريخ الحضور</span>
              <input name="arrivalDate" type="date" required />
            </label>
            <label>
              <span data-i18n="arrivalTime">وقت الحضور</span>
              <input name="arrivalTime" type="time" required />
            </label>
            <label class="notes-field">
              <span data-i18n="notesLabel">ملاحظات / Notes</span>
              <textarea name="notes" maxlength="500"></textarea>
            </label>
            <div class="modal-actions notes-field">
              <button class="modal-button modal-button-muted" type="button" id="back-services" data-i18n="back">تراجع</button>
              <button class="modal-button modal-button-gold" type="submit" data-i18n="continue">استمرار</button>
            </div>
          </form>
        </section>

        <section class="modal-step" data-step="confirm">
          <h3 data-i18n="confirm">التأكيد</h3>
          <div class="confirmation-summary" id="confirmation-summary"></div>
          <div class="modal-actions">
            <button class="modal-button modal-button-muted" type="button" id="back-details" data-i18n="back">تراجع</button>
            <button class="modal-button modal-button-gold" type="button" id="save-order" data-i18n="confirm">تأكيد</button>
          </div>
        </section>

        <section class="modal-step success-step" data-step="success">
          <Icon name="solar:check-circle-bold" />
          <h3 data-i18n="confirmed">تم التأكيد</h3>
          <p data-i18n="speakReception">يرجى التحدث مع الاستقبال</p>
          <button class="modal-button modal-button-gold" type="button" data-close-modal data-i18n="close">إغلاق</button>
        </section>
      </div>
    </dialog>

    <div class="upgrade-notice" id="upgrade-notice" role="status" aria-live="polite" hidden>
      <Icon name="solar:crown-star-bold" />
      <div>
        <strong data-i18n="upgradeTitle">قم بترقية الباقة</strong>
        <span data-i18n="upgradeMessage">للجمع بين الحمام المغربي وجلسة الفيشل، اختر العرض الملكي VIP.</span>
      </div>
      <button type="button" id="upgrade-close" aria-label="إغلاق">
        <Icon name="solar:close-circle-linear" />
      </button>
    </div>

    <div class="service-icon-templates" hidden>
      {Object.values(serviceById).map((service) => (
        <template data-icon-template={service.id}>
          <Icon name={service.icon} />
          {service.modifierIcon && <Icon class="choice-icon-modifier" name={service.modifierIcon} />}
        </template>
      ))}
    </div>

    <section class="visit-strip">
      <div class="site-container visit-strip-inner">
        <p data-i18n="address">دبي · أبو هيل · الممزر سنتر · داخل المول · طابق M</p>
        <a href="tel:+971509665607" dir="ltr">050 966 5607</a>
      </div>
    </section>
  </main>

  <footer class="site-container app-footer">
    <p>GHALY GENTS SALON</p>
    <p data-i18n="conceptPreview">Concept Preview</p>
  </footer>

  <script is:inline define:vars={{ packageData }}>
    // @ts-nocheck
    const modal = document.querySelector("#order-modal");
    const modalPackageName = document.querySelector("#modal-package-name");
    const selectionTitle = document.querySelector("#selection-title");
    const selectionDescription = document.querySelector("#selection-description");
    const selectionGrid = document.querySelector("#selection-grid");
    const selectionCount = document.querySelector("#selection-count");
    const selectionLimit = document.querySelector("#selection-limit");
    const continueDetails = document.querySelector("#continue-details");
    const autoContinue = document.querySelector("#auto-continue");
    const autoSeconds = document.querySelector("#auto-seconds");
    const customerForm = document.querySelector("#customer-form");
    const confirmationSummary = document.querySelector("#confirmation-summary");
    let activePackage = null;
    let selectedIds = [];
    let autoTimer = null;
    let secondsRemaining = 30;
    let language = localStorage.getItem("ghaly-language") || "ar";
    const translations = {
      ar: {
        heroEyebrow: "LUXURY STARTS WITH SELF CARE", heroTitle: "الفخامة تبدأ من العناية بنفسك",
        professionalService: "خدمة احترافية", guaranteedResults: "نتائج مضمونة", satisfactionGoal: "رضاكم هو هدفنا",
        formTitle: "استمارة اختيار الخدمات", services: "الخدمات", details: "البيانات", confirm: "التأكيد",
        autoContinue: "الانتقال إلى البيانات خلال", seconds: "ثانية", back: "تراجع", continue: "استمرار",
        nameLabel: "الاسم / Name", phoneLabel: "رقم الهاتف / Phone", arrivalDate: "تاريخ الحضور",
        arrivalTime: "وقت الحضور", notesLabel: "ملاحظات / Notes", confirmed: "تم التأكيد",
        speakReception: "يرجى التحدث مع الاستقبال", close: "إغلاق", fiveIncluded: "5 خدمات مشمولة",
        includedServices: "الخدمات المشمولة", chooseMood: (limit) => `اختر ${limit} خدمات بمزاجك`,
        availableRule: (limit, available) => `اختر ${limit} خدمات من بين ${available} خدمة متاحة`,
        chooseRequired: (limit) => `يرجى اختيار ${limit} خدمات`,
        upgradeTitle: "قم بترقية الباقة",
        upgradeMessage: "للجمع بين الحمام المغربي وجلسة الفيشل، اختر العرض الملكي VIP.",
        package: "العرض", selectedServices: "الخدمات", address: "دبي · أبو هيل · الممزر سنتر · داخل المول · طابق M",
        conceptPreview: "نموذج تصوري",
      },
      en: {
        heroEyebrow: "LUXURY STARTS WITH SELF CARE", heroTitle: "Luxury Starts With Self Care",
        professionalService: "Professional Service", guaranteedResults: "Guaranteed Results", satisfactionGoal: "Your Satisfaction Is Our Goal",
        formTitle: "Service Selection Form", services: "Services", details: "Details", confirm: "Confirm",
        autoContinue: "Continuing to details in", seconds: "seconds", back: "Back", continue: "Continue",
        nameLabel: "Name", phoneLabel: "Phone", arrivalDate: "Arrival Date",
        arrivalTime: "Arrival Time", notesLabel: "Notes", confirmed: "Confirmed",
        speakReception: "Please speak with reception", close: "Close", fiveIncluded: "5 Services Included",
        includedServices: "Included Services", chooseMood: (limit) => `Choose Any ${limit} Services`,
        availableRule: (limit, available) => `Choose ${limit} services from ${available} available services`,
        chooseRequired: (limit) => `Please choose ${limit} services`,
        upgradeTitle: "Upgrade Your Package",
        upgradeMessage: "To combine Moroccan Bath and Facial Session, choose the Royal VIP offer.",
        package: "Package", selectedServices: "Services", address: "Dubai · Abu Hail · Al Mamzar Centre · Inside the Mall · M Floor",
        conceptPreview: "Concept Preview",
      },
    };

    const applyLanguage = () => {
      const dictionary = translations[language];
      document.documentElement.lang = language === "ar" ? "ar-AE" : "en";
      document.documentElement.dir = language === "ar" ? "rtl" : "ltr";
      document.querySelector("#language-switch").textContent = language === "ar" ? "English" : "العربية";
      document.querySelectorAll("[data-i18n]").forEach((element) => {
        const value = dictionary[element.dataset.i18n];
        if (typeof value === "string") element.textContent = value;
      });
      document.querySelectorAll("[data-service-ar]").forEach((element) => {
        element.textContent = language === "ar" ? element.dataset.serviceAr : element.dataset.serviceEn;
      });
      document.querySelectorAll("[data-package-ar]").forEach((element) => {
        element.textContent = language === "ar" ? element.dataset.packageAr : element.dataset.packageEn;
      });
      document.querySelectorAll("[data-service-secondary]").forEach((element) => {
        element.textContent = language === "ar" ? element.dataset.serviceEn : element.dataset.serviceAr;
      });
      document.querySelectorAll("[data-package-rule]").forEach((element) => {
        element.textContent = element.dataset.fixed === "true"
          ? dictionary.includedServices
          : dictionary.chooseMood(element.dataset.limit);
      });
      document.querySelectorAll("[data-available-rule]").forEach((element) => {
        element.textContent = dictionary.availableRule(element.dataset.limit, element.dataset.available);
      });
    };

    const setStep = (step) => {
      document.querySelectorAll("[data-step]").forEach((section) => {
        section.classList.toggle("is-active", section.dataset.step === step);
      });
      document.querySelectorAll("[data-progress]").forEach((item) => {
        const order = ["services", "details", "confirm"];
        item.classList.toggle("is-active", order.indexOf(item.dataset.progress) <= order.indexOf(step));
      });
    };

    const stopAutoContinue = () => {
      if (autoTimer) window.clearInterval(autoTimer);
      autoTimer = null;
      autoContinue.hidden = true;
      secondsRemaining = 30;
      autoSeconds.textContent = "30";
    };

    const startAutoContinue = () => {
      if (autoTimer || activePackage.fixedServiceIds) return;
      autoContinue.hidden = false;
      autoTimer = window.setInterval(() => {
        secondsRemaining -= 1;
        autoSeconds.textContent = String(secondsRemaining);
        if (secondsRemaining <= 0) {
          stopAutoContinue();
          setStep("details");
        }
      }, 1000);
    };

    const updateSelection = () => {
      const isComplete = selectedIds.length === activePackage.limit;
      selectionCount.textContent = String(selectedIds.length);
      continueDetails.disabled = !isComplete;
      selectionGrid.querySelectorAll(".service-choice").forEach((choice) => {
        const selected = selectedIds.includes(choice.dataset.serviceId);
        const blockedByExclusiveChoice = activePackage.code === "offer_150"
          && ((choice.dataset.serviceId === "moroccan_bath" && selectedIds.includes("facial_session"))
          || (choice.dataset.serviceId === "facial_session" && selectedIds.includes("moroccan_bath")));
        choice.classList.toggle("is-selected", selected);
        choice.classList.toggle("is-exclusive-disabled", blockedByExclusiveChoice);
        choice.setAttribute("aria-pressed", String(selected));
        choice.disabled = !selected && isComplete && !blockedByExclusiveChoice;
      });
      if (isComplete) startAutoContinue();
      else stopAutoContinue();
      if (!selectedIds.includes("moroccan_bath") && !selectedIds.includes("facial_session")) {
        document.querySelector("#upgrade-notice").hidden = true;
      }
    };

    const renderServices = () => {
      selectionGrid.replaceChildren();
      activePackage.services.forEach((service) => {
        const choice = document.createElement("button");
        choice.type = "button";
        choice.className = "service-choice";
        choice.dataset.serviceId = service.id;
        choice.setAttribute("aria-pressed", "false");
        const iconWrap = document.createElement("span");
        const textWrap = document.createElement("span");
        const arabicName = document.createElement("strong");
        const englishName = document.createElement("small");
        iconWrap.className = "choice-icon";
        const iconTemplate = document.querySelector(`[data-icon-template="${service.id}"]`);
        if (iconTemplate) iconWrap.append(iconTemplate.content.cloneNode(true));
        arabicName.textContent = language === "ar" ? service.ar : service.en;
        englishName.textContent = language === "ar" ? service.en : service.ar;
        textWrap.append(arabicName, englishName);
        choice.append(iconWrap, textWrap);
        choice.addEventListener("click", () => {
          if (activePackage.fixedServiceIds) return;
          const isExclusiveBlocked = activePackage.code === "offer_150"
            && ((service.id === "moroccan_bath" && selectedIds.includes("facial_session"))
            || (service.id === "facial_session" && selectedIds.includes("moroccan_bath")));
          if (isExclusiveBlocked) {
            document.querySelector("#upgrade-notice").hidden = false;
            return;
          }
          selectedIds = selectedIds.includes(service.id)
            ? selectedIds.filter((id) => id !== service.id)
            : [...selectedIds, service.id];
          updateSelection();
        });
        selectionGrid.append(choice);
      });
      updateSelection();
    };

    const openPackage = (code) => {
      activePackage = packageData.find((item) => item.code === code);
      selectedIds = activePackage.fixedServiceIds ? [...activePackage.fixedServiceIds] : [];
      customerForm.reset();
      stopAutoContinue();
      modalPackageName.textContent = language === "ar" ? activePackage.ar : activePackage.en;
      selectionTitle.textContent = activePackage.fixedServiceIds
        ? translations[language].fiveIncluded
        : translations[language].chooseRequired(activePackage.limit);
      selectionDescription.textContent = activePackage.fixedServiceIds
        ? activePackage.ar
        : translations[language].availableRule(activePackage.limit, activePackage.services.length);
      selectionLimit.textContent = `/ ${activePackage.limit}`;
      if (activePackage.fixedServiceIds) {
        setStep("details");
      } else {
        setStep("services");
        renderServices();
      }
      modal.showModal();
      applyLanguage();
    };

    document.querySelector("#language-switch").addEventListener("click", () => {
      language = language === "ar" ? "en" : "ar";
      localStorage.setItem("ghaly-language", language);
      applyLanguage();
      if (activePackage && modal.open) {
        modalPackageName.textContent = language === "ar" ? activePackage.ar : activePackage.en;
        selectionTitle.textContent = activePackage.fixedServiceIds
          ? translations[language].fiveIncluded
          : translations[language].chooseRequired(activePackage.limit);
        selectionDescription.textContent = activePackage.fixedServiceIds
          ? (language === "ar" ? activePackage.ar : activePackage.en)
          : translations[language].availableRule(activePackage.limit, activePackage.services.length);
      }
    });

    document.querySelectorAll("[data-package-code]").forEach((trigger) => {
      trigger.addEventListener("click", () => openPackage(trigger.dataset.packageCode));
    });

    document.querySelectorAll("[data-close-modal]").forEach((button) => {
      button.addEventListener("click", () => {
        stopAutoContinue();
        modal.close();
      });
    });

    continueDetails.addEventListener("click", () => {
      stopAutoContinue();
      setStep("details");
    });
    document.querySelector("#back-services").addEventListener("click", () => setStep("services"));
    document.querySelector("#back-details").addEventListener("click", () => setStep("details"));

    customerForm.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = Object.fromEntries(new FormData(customerForm));
      const chosenServices = selectedIds.map((id) => activePackage.services.find((service) => service.id === id));
      confirmationSummary.replaceChildren();
      const addSummaryRow = (label, value, direction) => {
        const row = document.createElement("div");
        const labelElement = document.createElement("span");
        const valueElement = document.createElement("strong");
        labelElement.textContent = label;
        valueElement.textContent = value;
        if (direction) valueElement.dir = direction;
        row.append(labelElement, valueElement);
        confirmationSummary.append(row);
      };
      addSummaryRow(translations[language].package, activePackage.en);
      addSummaryRow(translations[language].nameLabel, data.customerName);
      addSummaryRow(translations[language].phoneLabel, data.phone, "ltr");
      addSummaryRow(translations[language].arrivalDate, data.arrivalDate);
      addSummaryRow(translations[language].arrivalTime, data.arrivalTime);
      const servicesRow = document.createElement("div");
      const servicesLabel = document.createElement("span");
      const servicesList = document.createElement("ul");
      servicesLabel.textContent = translations[language].selectedServices;
      chosenServices.forEach((service) => {
        const item = document.createElement("li");
        item.textContent = language === "ar" ? service.ar : service.en;
        servicesList.append(item);
      });
      servicesRow.append(servicesLabel, servicesList);
      confirmationSummary.append(servicesRow);
      if (data.notes) addSummaryRow(translations[language].notesLabel, data.notes);
      setStep("confirm");
    });

    document.querySelector("#save-order").addEventListener("click", () => {
      const data = Object.fromEntries(new FormData(customerForm));
      const draftOrder = {
        packageCode: activePackage.code,
        selectedServiceIds: selectedIds,
        ...data,
        savedAt: new Date().toISOString(),
      };
      localStorage.setItem("ghaly-demo-order", JSON.stringify(draftOrder));
      setStep("success");
    });

    modal.addEventListener("click", (event) => {
      if (event.target === modal) {
        stopAutoContinue();
        modal.close();
      }
    });
    modal.addEventListener("cancel", stopAutoContinue);
    document.querySelector("#upgrade-close").addEventListener("click", () => {
      document.querySelector("#upgrade-notice").hidden = true;
    });
    applyLanguage();
  </script>
</BaseLayout>

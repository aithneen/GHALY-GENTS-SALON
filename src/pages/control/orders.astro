
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrdersList from '../../components/OrdersList.svelte';

export const prerender = false;
---

<BaseLayout title="طلبات الصالون | Ghaly Gents Salon" description="لوحة استقبال طلبات صالون غالي">
  <main class="control-shell">
    <OrdersList client:load />
  </main>
</BaseLayout>

<style is:global>
  body {
    background: #080704;
  }
  .control-shell {
    max-width: 1440px;
    margin-inline: auto;
    padding: 24px;
    color: #fff;
    direction: rtl;
  }
  .control-header {
    display: flex;
    gap: 24px;
    align-items: flex-end;
    justify-content: space-between;
    margin-block-end: 28px;
    padding: 28px;
    border: 1px solid #493713;
    border-radius: 24px;
    background: linear-gradient(135deg, #17130b, #090806);
  }
  .control-header p,
  .control-header span {
    color: #bba870;
  }
  .control-header h1 {
    margin: 4px 0;
    font-size: clamp(2.3rem, 6vw, 4.5rem);
    color: #f0d07a;
  }
  .header-actions,
  .detail-actions,
  .card-actions,
  .row-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .header-actions button {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .header-actions svg {
    inline-size: 18px;
    block-size: 18px;
  }
  .control-shell button,
  .control-shell a,
  .control-filters select {
    min-height: 44px;
    border: 1px solid #6d5119;
    border-radius: 11px;
    padding: 9px 14px;
    background: #18130a;
    color: #fff;
    text-decoration: none;
    cursor: pointer;
  }
  .control-shell button:hover,
  .control-shell a:hover {
    border-color: #d49a22;
    background: #2a200e;
  }
  .control-shell .primary-action {
    background: #d49a22;
    color: #090704;
    font-weight: 800;
  }
  .icon-action {
    display: grid !important;
    inline-size: 36px;
    block-size: 36px;
    min-height: 36px !important;
    flex: 0 0 36px !important;
    place-items: center;
    padding: 8px !important;
    border-radius: 9px !important;
  }
  .icon-action svg {
    inline-size: 17px;
    block-size: 17px;
  }
  .whatsapp-action {
    color: #72d391 !important;
  }
  .control-filters {
    display: flex;
    gap: 14px;
    align-items: end;
    flex-wrap: wrap;
    margin-block-end: 24px;
    padding: 18px;
    border: 1px solid #302612;
    border-radius: 18px;
    background: #100e09;
  }
  .control-filters label {
    display: grid;
    gap: 6px;
    color: #c7b785;
  }
  .control-filters select {
    min-width: 170px;
  }
  .check-filter {
    display: flex !important;
    min-height: 44px;
    align-items: center !important;
  }
  .control-filters p {
    margin-inline-start: auto;
    color: #f0d07a;
  }
  .orders-table-wrap {
    overflow: auto;
    border: 1px solid #3c2e13;
    border-radius: 20px;
    background: #0f0d09;
  }
  .orders-table {
    width: 100%;
    min-width: 1080px;
    border-collapse: separate;
    border-spacing: 0;
  }
  .orders-table th {
    position: sticky;
    inset-block-start: 0;
    background: #211a0d;
    color: #fff;
    padding: 12px 16px;
    font-weight: 700;
    text-align: right;
  }
  .orders-table td {
    padding: 12px 16px;
    border-top: 1px solid #3c2e13;
  }
  .orders-table .queue-cell {
    color: #f0d07a;
    font-weight: 700;
  }
  .orders-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
    margin-top: 24px;
  }
  .order-card {
    padding: 20px;
    border: 1px solid #3c2e13;
    border-radius: 16px;
    background: #100e09;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .order-card:hover {
    border-color: #6d5119;
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 16px;
  }
  .card-top h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }
  .queue-badge {
    padding: 4px 12px;
    border-radius: 999px;
    background: #211a0d;
    color: #f0d07a;
    font-weight: 700;
  }
  .card-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 16px;
  }
  .card-meta span {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .card-meta small {
    color: #bba870;
  }
  .card-meta strong {
    color: #fff;
  }
  .control-dialog {
    position: fixed;
    inset: 0;
    border: 0;
    background: transparent;
    padding: 0;
  }
  .control-dialog::backdrop {
    background: rgba(8, 7, 4, 0.8);
  }
  .control-dialog-inner {
    max-width: 600px;
    margin-inline: auto;
    margin-block: 24px;
    padding: 24px;
    border: 1px solid #493713;
    border-radius: 24px;
    background: linear-gradient(135deg, #17130b, #090806);
  }
  .control-dialog-inner header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }
  .control-dialog-inner header button {
    background: transparent;
    border: 1px solid #6d5119;
    color: #fff;
    padding: 8px 16px;
    border-radius: 11px;
    cursor: pointer;
    font-size: 1.5rem;
  }
  .control-dialog-inner h3 {
    font-size: 1.125rem;
    margin-top: 24px;
    margin-bottom: 12px;
  }
  .control-dialog-inner p {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin: 8px 0;
  }
  .control-dialog-inner strong {
    color: #bba870;
  }
  .control-dialog-inner ul {
    padding-right: 20px;
    margin: 0;
  }
  .copy-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    padding: 12px 24px;
    border: 1px solid #6d5119;
    border-radius: 11px;
    background: #18130a;
    color: #f0d07a;
    font-weight: 700;
    z-index: 1000;
  }
</style>

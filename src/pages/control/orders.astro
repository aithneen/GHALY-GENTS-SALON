---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { packages } from "../../config/packages";
import { services } from "../../config/services";

export const prerender = false;

const referenceData = {
  packages: Object.fromEntries(packages.map((item) => [item.code, item.ar])),
  services: Object.fromEntries(services.map((item) => [item.id, item.ar])),
};
---

<BaseLayout title="طلبات الصالون | Ghaly Gents Salon" description="لوحة استقبال طلبات صالون غالي">
  <main class="control-shell">
    <header class="control-header">
      <div>
        <p>GHALY GENTS SALON</p>
        <h1>طلبات الصالون</h1>
        <span>تحديث تلقائي كل 15 ثانية</span>
      </div>
      <div class="header-actions">
        <button id="export-csv" type="button">تحميل CSV</button>
        <button id="refresh-orders" type="button">تحديث القائمة</button>
      </div>
    </header>

    <section class="control-filters" aria-label="فلاتر الطلبات">
      <label><span>الحالة</span><select id="status-filter">
        <option value="">جميع الحالات</option><option value="new">جديد</option>
        <option value="acknowledged">تم الاطلاع</option><option value="completed">مكتمل</option>
        <option value="cancelled">ملغي</option>
      </select></label>
      <label><span>المصدر</span><select id="source-filter">
        <option value="">جميع الطلبات</option><option value="in_salon">داخل الصالون</option><option value="home">من المنزل</option>
      </select></label>
      <label class="check-filter"><input id="today-filter" type="checkbox" /> مواعيد اليوم</label>
      <p id="orders-state" role="status">جاري تحميل الطلبات...</p>
    </section>

    <section class="orders-table-wrap">
      <table class="orders-table">
        <thead><tr><th>الترتيب</th><th>الطلب</th><th>العميل</th><th>الهاتف</th><th>العرض</th><th>الموعد</th><th>الحالة</th><th>الإجراءات</th></tr></thead>
        <tbody id="orders-table-body"></tbody>
      </table>
    </section>
    <section class="orders-cards" id="orders-cards"></section>

    <dialog class="control-dialog" id="order-details">
      <div class="control-dialog-inner">
        <header><div><small>GHALY GENTS SALON</small><h2 id="details-title">تفاصيل الطلب</h2></div><button type="button" id="close-details" aria-label="إغلاق">×</button></header>
        <div class="detail-actions" id="detail-actions"></div>
        <div class="details-content" id="details-content"></div>
        <footer id="status-actions"></footer>
      </div>
    </dialog>
    <div class="copy-toast" id="copy-toast" role="status" hidden>تم النسخ</div>
  </main>

  <script is:inline define:vars={{ referenceData }}>
    const statusLabels = { new: "جديد", acknowledged: "تم الاطلاع", completed: "مكتمل", cancelled: "ملغي" };
    const sourceLabels = { home: "من المنزل", in_salon: "داخل الصالون" };
    const state = document.querySelector("#orders-state");
    const tableBody = document.querySelector("#orders-table-body");
    const cards = document.querySelector("#orders-cards");
    const dialog = document.querySelector("#order-details");
    let orders = [];

    const packageName = (code) => referenceData.packages[code] || code;
    const serviceName = (id) => referenceData.services[id] || id;
    const formatDate = (value) => new Intl.DateTimeFormat("ar-AE", { dateStyle: "medium", timeStyle: "short" }).format(new Date(`${value}Z`));
    const appointment = (order) => order.order_source === "home" ? `${order.arrival_date} · ${order.arrival_time}` : "داخل الصالون الآن";
    const queueLabel = (order) => order.queue_position ? `رقم الانتظار ${order.queue_position}` : order.order_source === "home" ? "موعد منزلي" : "خارج الانتظار";
    const phoneDigits = (phone) => {
      const digits = String(phone || "").replace(/\D/g, "");
      return digits.startsWith("0") ? `971${digits.slice(1)}` : digits;
    };
    const orderText = (order) => [
      `طلب #${order.id}`, `المصدر: ${sourceLabels[order.order_source]}`, order.queue_position ? `رقم الانتظار: ${order.queue_position}` : "",
      `العميل: ${order.customer_name}`, `الهاتف: ${order.phone || "—"}`, `العرض: ${packageName(order.package_code)}`,
      `الموعد: ${appointment(order)}`, `الحالة: ${statusLabels[order.status]}`,
      `الخدمات: ${order.selectedServiceIds.map(serviceName).join("، ")}`, `الملاحظات: ${order.notes || "—"}`,
    ].filter(Boolean).join("\n");

    const showCopied = () => {
      const toast = document.querySelector("#copy-toast"); toast.hidden = false;
      window.setTimeout(() => { toast.hidden = true; }, 1500);
    };
    const copyText = async (text) => { await navigator.clipboard.writeText(text); showCopied(); };
    const makeAction = (label, handler, className = "") => {
      const button = document.createElement("button"); button.type = "button"; button.textContent = label; button.className = className;
      button.addEventListener("click", (event) => { event.stopPropagation(); handler(); }); return button;
    };
    const icons = {
      call: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24c1.1.36 2.3.55 3.5.55a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.6 21 3 13.4 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.2.19 2.4.55 3.5a1 1 0 0 1-.25 1Z"/></svg>',
      whatsapp: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 11.6a8 8 0 0 1-11.9 7l-4.1 1.1 1.1-4A8 8 0 1 1 20 11.6Z"/><path d="M9 8.5c.2 2.3 2.2 4.2 4.5 4.5l1.1-1.1 2 .9c-.5 1.6-1.5 2.4-3 2.2-3.5-.5-6.1-3.1-6.6-6.6-.2-1.5.6-2.5 2.2-3l.9 2Z"/></svg>',
      more: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>',
    };
    const makeIconAction = (label, icon, handler, className = "") => {
      const button = document.createElement("button"); button.type = "button"; button.className = `icon-action ${className}`.trim();
      button.title = label; button.setAttribute("aria-label", label); button.innerHTML = icon;
      button.addEventListener("click", (event) => { event.stopPropagation(); handler(); }); return button;
    };
    const appendContactActions = (container, order, mode = "compact") => {
      if (order.phone) {
        const call = document.createElement("a"); call.href = `tel:${order.phone}`; call.title = "اتصال"; call.setAttribute("aria-label", "اتصال"); call.className = "icon-action"; call.innerHTML = icons.call; call.addEventListener("click", (event) => event.stopPropagation()); container.append(call);
        const whatsapp = document.createElement("a"); whatsapp.href = `https://wa.me/${phoneDigits(order.phone)}`; whatsapp.target = "_blank"; whatsapp.rel = "noreferrer"; whatsapp.title = "واتساب"; whatsapp.setAttribute("aria-label", "واتساب"); whatsapp.className = "icon-action whatsapp-action"; whatsapp.innerHTML = icons.whatsapp; whatsapp.addEventListener("click", (event) => event.stopPropagation()); container.append(whatsapp);
        if (mode === "full") container.append(makeAction("نسخ الرقم", () => copyText(order.phone)));
      }
      if (mode === "full") container.append(makeAction("نسخ الطلب", () => copyText(orderText(order))));
      else container.append(makeIconAction("المزيد من التفاصيل", icons.more, () => openDetails(order.id), "primary-action"));
    };

    const openDetails = (id) => {
      const order = orders.find((item) => item.id === id); if (!order) return;
      document.querySelector("#details-title").textContent = `طلب #${order.id} · ${queueLabel(order)}`;
      const content = document.querySelector("#details-content"); content.replaceChildren();
      [
        ["المصدر", sourceLabels[order.order_source]], ["العميل", order.customer_name], ["الهاتف", order.phone || "—"],
        ["العرض", packageName(order.package_code)], ["الموعد", appointment(order)], ["تفضيل الموظف", order.staff_preference || "—"],
        ["ملاحظات", order.notes || "—"], ["وقت الطلب", formatDate(order.created_at)],
      ].forEach(([label, value]) => {
        const row = document.createElement("p"); const strong = document.createElement("strong"); const span = document.createElement("span");
        strong.textContent = label; span.textContent = value; row.append(strong, span); content.append(row);
      });
      const listTitle = document.createElement("h3"); listTitle.textContent = "الخدمات المختارة";
      const list = document.createElement("ul"); order.selectedServiceIds.forEach((id) => { const item = document.createElement("li"); item.textContent = serviceName(id); list.append(item); });
      content.append(listTitle, list);
      const contact = document.querySelector("#detail-actions"); contact.replaceChildren(); appendContactActions(contact, order, "full");
      const actions = document.querySelector("#status-actions"); actions.replaceChildren();
      Object.entries(statusLabels).forEach(([status, label]) => {
        const button = makeAction(label, () => updateStatus(order.id, status)); button.disabled = status === order.status; actions.append(button);
      });
      dialog.showModal();
    };

    const render = () => {
      tableBody.replaceChildren(); cards.replaceChildren();
      orders.forEach((order) => {
        const row = document.createElement("tr");
        [queueLabel(order), `#${order.id}\n${formatDate(order.created_at)}`, order.customer_name, order.phone || "—", packageName(order.package_code), appointment(order), statusLabels[order.status]].forEach((value, index) => {
          const cell = document.createElement("td"); cell.textContent = value; if (index === 0 && order.queue_position) cell.className = "queue-cell"; row.append(cell);
        });
        const actions = document.createElement("td"); actions.className = "row-actions"; appendContactActions(actions, order); row.append(actions); tableBody.append(row);

        const card = document.createElement("article"); card.className = "order-card"; card.dataset.status = order.status;
        const top = document.createElement("div"); top.className = "card-top";
        const heading = document.createElement("div"); const title = document.createElement("h2"); title.textContent = order.customer_name;
        const subtitle = document.createElement("span"); subtitle.textContent = `طلب #${order.id} · ${sourceLabels[order.order_source]}`; heading.append(title, subtitle);
        const queue = document.createElement("strong"); queue.className = "queue-badge"; queue.textContent = queueLabel(order); top.append(heading, queue);
        const meta = document.createElement("div"); meta.className = "card-meta";
        [
          ["العرض", packageName(order.package_code)],
          ["الموعد", appointment(order)],
          ["الخدمات", `${order.selectedServiceIds.length} خدمات`],
          ["الحالة", statusLabels[order.status]],
        ].forEach(([label, value]) => { const item = document.createElement("span"); const small = document.createElement("small"); const strong = document.createElement("strong"); small.textContent = label; strong.textContent = value; item.append(small, strong); meta.append(item); });
        const cardActions = document.createElement("div"); cardActions.className = "card-actions"; appendContactActions(cardActions, order);
        card.addEventListener("click", () => openDetails(order.id));
        card.append(top, meta, cardActions); cards.append(card);
      });
      state.textContent = orders.length ? `${orders.length} طلب` : "لا توجد طلبات";
    };

    const loadOrders = async () => {
      state.textContent = "جاري التحديث...";
      const params = new URLSearchParams(); const status = document.querySelector("#status-filter").value; const source = document.querySelector("#source-filter").value;
      if (status) params.set("status", status); if (source) params.set("source", source); if (document.querySelector("#today-filter").checked) params.set("date", "today");
      try { const response = await fetch(`/api/control/orders?${params}`); const result = await response.json(); if (!response.ok) throw new Error(result.error); orders = result.orders; render(); }
      catch { state.textContent = "تعذر تحميل الطلبات"; }
    };
    const updateStatus = async (id, status) => {
      const response = await fetch(`/api/control/orders/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status }) });
      if (response.ok) { dialog.close(); await loadOrders(); }
    };
    const exportCsv = () => {
      const quote = (value) => `"${String(value ?? "").replaceAll('"', '""')}"`;
      const rows = [["id","queue","source","customer","phone","package","appointment","status","services","notes"], ...orders.map((order) => [
        order.id, order.queue_position || "", order.order_source, order.customer_name, order.phone, packageName(order.package_code), appointment(order), order.status, order.selectedServiceIds.map(serviceName).join(" | "), order.notes || "",
      ])];
      const blob = new Blob(["\uFEFF" + rows.map((row) => row.map(quote).join(",")).join("\n")], { type: "text/csv;charset=utf-8" });
      const link = document.createElement("a"); link.href = URL.createObjectURL(blob); link.download = `ghaly-orders-${new Date().toISOString().slice(0,10)}.csv`; link.click(); URL.revokeObjectURL(link.href);
    };
    document.querySelector("#refresh-orders").addEventListener("click", loadOrders);
    document.querySelector("#export-csv").addEventListener("click", exportCsv);
    document.querySelector("#status-filter").addEventListener("change", loadOrders);
    document.querySelector("#source-filter").addEventListener("change", loadOrders);
    document.querySelector("#today-filter").addEventListener("change", loadOrders);
    document.querySelector("#close-details").addEventListener("click", () => dialog.close());
    loadOrders(); window.setInterval(loadOrders, 15000);
  </script>
</BaseLayout>

<style>
  :global(body){background:#080704}.control-shell{max-width:1440px;margin-inline:auto;padding:24px;color:#fff;direction:rtl}.control-header{display:flex;gap:24px;align-items:flex-end;justify-content:space-between;margin-block-end:28px;padding:28px;border:1px solid #493713;border-radius:24px;background:linear-gradient(135deg,#17130b,#090806)}.control-header p,.control-header span{color:#bba870}.control-header h1{margin:4px 0;font-size:clamp(2.3rem,6vw,4.5rem);color:#f0d07a}.header-actions,.detail-actions,.card-actions,.row-actions{display:flex;gap:8px;flex-wrap:wrap}.control-shell button,.control-shell a,.control-filters select{min-height:44px;border:1px solid #6d5119;border-radius:11px;padding:9px 14px;background:#18130a;color:#fff;text-decoration:none;cursor:pointer}.control-shell button:hover,.control-shell a:hover{border-color:#d49a22;background:#2a200e}.control-shell .primary-action{background:#d49a22;color:#090704;font-weight:800}.icon-action{display:grid!important;inline-size:44px;block-size:44px;min-height:44px!important;flex:0 0 44px!important;place-items:center;padding:10px!important}.icon-action svg{inline-size:21px;block-size:21px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}.icon-action svg circle{fill:currentColor;stroke:none}.whatsapp-action{color:#72d391!important}.control-filters{display:flex;gap:14px;align-items:end;flex-wrap:wrap;margin-block-end:24px;padding:18px;border:1px solid #302612;border-radius:18px;background:#100e09}.control-filters label{display:grid;gap:6px;color:#c7b785}.control-filters select{min-width:170px}.check-filter{display:flex!important;min-height:44px;align-items:center!important}.control-filters p{margin-inline-start:auto;color:#f0d07a}.orders-table-wrap{overflow:auto;border:1px solid #3c2e13;border-radius:20px;background:#0f0d09}.orders-table{width:100%;min-width:1100px;border-collapse:separate;border-spacing:0}.orders-table th{position:sticky;inset-block-start:0;background:#211a0d;color:#f0d07a;font-size:.8rem}.orders-table th,.orders-table td{padding:20px 16px;border-block-end:1px solid #2b2212;text-align:start;white-space:pre-line;line-height:1.75}.orders-table tbody tr:hover{background:#17130b}.queue-cell{color:#f0d07a;font-weight:800}.row-actions{min-width:160px;justify-content:flex-start}.orders-cards{display:none}.control-dialog{width:min(760px,calc(100% - 24px));max-height:90vh;border:1px solid #d49a22;border-radius:22px;background:#0c0a07;color:#fff}.control-dialog::backdrop{background:#000b;backdrop-filter:blur(5px)}.control-dialog-inner{padding:24px}.control-dialog header{display:flex;justify-content:space-between;align-items:center;margin-block-end:16px}.control-dialog h2{margin:4px 0;color:#f0d07a}.details-content{display:grid;gap:0;margin-block:18px}.details-content p{display:grid;grid-template-columns:145px 1fr;gap:14px;margin:0;padding:13px 0;border-block-end:1px solid #2b2212;line-height:1.7}.details-content ul{columns:2;line-height:2}.control-dialog footer{display:flex;gap:8px;flex-wrap:wrap;padding-block-start:18px;border-block-start:1px solid #2b2212}.control-dialog button:disabled{opacity:.35}.copy-toast{position:fixed;z-index:200;inset-inline-start:50%;inset-block-end:24px;transform:translateX(-50%);border:1px solid #d49a22;border-radius:999px;background:#18130a;padding:12px 22px;color:#f0d07a}.order-card{display:grid;gap:18px;border:1px solid #493713;border-radius:20px;background:linear-gradient(145deg,#17130b,#0d0b07);padding:18px;cursor:pointer}.card-top{display:flex;gap:12px;justify-content:space-between;align-items:start}.card-top h2{margin:0;color:#fff;font-size:1.25rem}.card-top span{color:#a99973;font-size:.8rem}.queue-badge{border:1px solid #d49a22;border-radius:999px;padding:7px 10px;color:#f0d07a;white-space:nowrap}.card-meta{display:grid;grid-template-columns:1fr 1fr;gap:8px}.card-meta span{display:grid;gap:3px;border-radius:9px;background:#211a0d;padding:9px;color:#d9cba5}.card-meta small{color:#93835d;font-size:.68rem}.card-meta strong{font-size:.82rem}.card-actions{justify-content:flex-end}.control-dialog button:focus-visible,.control-shell a:focus-visible,.control-shell select:focus-visible{outline:2px solid #f0d07a;outline-offset:2px}@media(max-width:767px){.control-shell{padding:10px}.control-header{align-items:start;flex-direction:column;margin-block-end:14px;padding:20px;border-radius:20px}.control-header h1{font-size:2.25rem}.header-actions{display:grid;grid-template-columns:1fr 1fr;width:100%}.header-actions button{width:100%}.control-filters{align-items:stretch;gap:10px;margin-block-end:14px;padding:14px;border-radius:16px}.control-filters label,.control-filters select{width:100%}.control-filters p{margin:4px 0 0;text-align:center}.orders-table-wrap{display:none}.orders-cards{display:grid;gap:14px}.order-card{position:relative;gap:16px;min-height:260px;border-radius:22px;padding:20px;box-shadow:0 14px 34px #0006}.order-card::before{position:absolute;inset-block:0;inset-inline-start:0;width:4px;border-radius:22px 0 0 22px;background:#d49a22;content:""}.order-card[data-status="completed"]::before{background:#5fa876}.order-card[data-status="cancelled"]::before{background:#9d5656}.order-card:active{transform:scale(.985)}.card-top h2{font-size:1.4rem;line-height:1.4}.card-top span{display:block;margin-block-start:4px;font-size:.78rem}.queue-badge{padding:8px 11px;font-size:.75rem}.card-meta{gap:10px}.card-meta span{min-height:62px;padding:10px}.card-actions{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding-block-start:14px;border-block-start:1px solid #302612}.card-actions .icon-action{width:100%!important;block-size:52px;min-height:52px!important;border-radius:14px}.details-content p{grid-template-columns:1fr}.details-content ul{columns:1}.control-dialog{width:100%;max-width:none;max-height:94vh;margin-block-end:0;border-radius:24px 24px 0 0}.control-dialog-inner{padding:20px}.detail-actions{display:grid;grid-template-columns:1fr 1fr}.detail-actions>*{width:100%;text-align:center}.control-dialog footer{display:grid;grid-template-columns:1fr 1fr}.control-dialog footer button{width:100%}}
</style>
